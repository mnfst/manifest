{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "manifest#build": {
      "dependsOn": ["manifest-frontend#build", "manifest-backend#build"],
      "outputs": ["dist/**", "public/**"]
    },
    "manifest-provider#build": {
      "dependsOn": ["manifest-shared#build"],
      "outputs": ["dist/**", "skills/**"]
    },
    "test": {
      "cache": false
    },
    "lint": {
      "cache": false
    }
  }
}
