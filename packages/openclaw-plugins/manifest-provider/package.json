{
  "name": "manifest-provider",
  "version": "5.32.0",
  "description": "Smart LLM router plugin for OpenClaw — picks the best model for each request, balancing quality, speed, and cost",
  "main": "dist/index.js",
  "license": "MIT",
  "author": "MNFST Inc.",
  "homepage": "https://manifest.build",
  "repository": {
