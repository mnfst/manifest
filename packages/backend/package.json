{
  "name": "manifest-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "rm -f tsconfig.build.tsbuildinfo && nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "lint": "eslint src/",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/datasource.ts",
    "migration:run": "ts-node -T src/database/migrate.ts",
    "migration:run:prod": "node dist/database/migrate.js",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/datasource.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/database/datasource.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "backfill:message-providers": "ts-node -T src/database/backfills/backfill-message-providers.cli.ts",
    "backfill:message-providers:prod": "node dist/database/backfills/backfill-message-providers.cli.js"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/typeorm": "^11.0.3",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.4",
    "better-auth": "^1.6.23",
    "cache-manager": "^7.2.9",
    "cacheable": "^2.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "eventsource-parser": "^3.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "manifest-shared": "*",
    "modelparams": "^0.0.5",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.27",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts",
      "tsx"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.spec.ts",
      "!main.ts",
      "!**/database/migrations/**",
      "!**/database/datasource.ts",
      "!**/database/data-source-definitions.ts",
      "!**/database/migrate.ts",
      "!**/*.module.ts",
      "!**/otlp/interfaces/index.ts",
      "!**/otlp/proto/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
